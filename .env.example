# Headcount Time Series Approximater - environment configuration.
# Copy to .env and adjust as needed. All keys are read by
# src/headcount/config/settings.py via pydantic-settings.

# --- Core paths and runtime --------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO
LOG_FORMAT=json
DB_URL=sqlite:///./data/headcount.sqlite
DUCKDB_PATH=./data/outputs/headcount.duckdb
CACHE_DIR=./data/cache
RUN_ARTIFACT_DIR=./data/outputs/runs
SEED_DIR=./data/seeds
FIXTURE_DIR=./data/fixtures

# --- Method versioning -------------------------------------------------------
METHOD_VERSION=hc-v1
ANCHOR_POLICY_VERSION=anchor-v1
COVERAGE_CURVE_VERSION=coverage-v1

# --- LinkedIn public observer (fail-closed, bounded) -------------------------
LINKEDIN_PUBLIC_MAX_REQUESTS_PER_RUN=400
LINKEDIN_PUBLIC_MAX_RPM=6
LINKEDIN_PUBLIC_CIRCUIT_BREAKER_N=5
LINKEDIN_PUBLIC_REQUEST_JITTER_MS_MIN=250
LINKEDIN_PUBLIC_REQUEST_JITTER_MS_MAX=1750
# Seconds the circuit breaker stays open after it trips. After this
# window the streak resets and slug-resolver / observer callers may
# probe LinkedIn again. The cohort runner's --retry-breaker-skips flag
# sleeps through this window and retries parked companies.
LINKEDIN_PUBLIC_CIRCUIT_COOLDOWN_SECONDS=900
LINKEDIN_PUBLIC_COMPANY_TTL_DAYS=30
LINKEDIN_PUBLIC_PROFILE_TTL_DAYS=90

# --- Other sources -----------------------------------------------------------
COMPANY_WEB_MAX_CONCURRENCY=4
SEC_USER_AGENT=Headcount Estimator internal-use contact@example.com
WIKIDATA_ENDPOINT=https://query.wikidata.org/sparql

# --- Estimation thresholds ---------------------------------------------------
MIN_CURRENT_PROFILE_SAMPLE_6M=30
MIN_CURRENT_PROFILE_SAMPLE_1Y=50
MIN_CURRENT_PROFILE_SAMPLE_2Y=80
BENCHMARK_DISAGREEMENT_PCT_CURRENT=0.15
BENCHMARK_DISAGREEMENT_PCT_2Y=0.25

# --- API ---------------------------------------------------------------------
API_HOST=127.0.0.1
API_PORT=8000
METRICS_ENABLED=true
